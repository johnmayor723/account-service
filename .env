##########################################
# APPLICATION
##########################################

SERVICE_NAME=banking-platform-template

SERVICE_VERSION=1.0.0

NODE_ENV=development

PORT=3000

API_PREFIX=/api/v1

##########################################
# DATABASE
##########################################

MONGO_URI=mongodb://localhost:27017/banking-platform

##########################################
# SECURITY
##########################################

JWT_SECRET=CHANGE_ME

JWT_EXPIRATION=1h

##########################################
# REDIS
##########################################

REDIS_URL=redis://localhost:6379

##########################################
# LOGGING
##########################################

LOG_LEVEL=info
